# Copy this file to `.env.local` and fill in the values you actually
# have. .env.local is git-ignored.

# ─── Supabase (auth + DB) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── /api/feedback email transport ────────────────────────────────────────
# Pick ONE. Resend wins over Gmail SMTP if both are set. Console-log is
# the fallback if neither is set.

# OPTION A — Gmail SMTP. Requires a Gmail App Password (16-char), NOT
# the regular account password. Generate at
# https://myaccount.google.com/apppasswords (2-Step Verification must
# be on).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# OPTION B — Resend. Verified domain required for non-test sending.
RESEND_API_KEY=
RESEND_FROM=Surven Feedback <feedback@surven.ai>
